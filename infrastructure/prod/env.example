# Production environment template — copy to /etc/pgmanage/.env on the server
# (chmod 600, owned by root). Do NOT commit a populated copy.
#
# Generate strong values for SECRET_KEY, POSTGRES_PASSWORD, REDIS_PASSWORD with:
#   openssl rand -hex 32
#
# Generate the RS256 keypair with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt-private.pem
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# Then paste each as a single line with literal \n in place of newlines, e.g.:
#   JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"

# ── Domain & TLS ───────────────────────────────────────────────────────────────
DOMAIN=pgmanage.in
LETSENCRYPT_EMAIL=you@example.com
CORS_ORIGINS=https://pgmanage.in,https://www.pgmanage.in
ALLOWED_HOSTS=pgmanage.in,www.pgmanage.in

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=pgmanage
POSTGRES_PASSWORD=                # openssl rand -hex 32
POSTGRES_DB=pgmanage

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=                   # openssl rand -hex 32

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=                       # openssl rand -hex 32
RS256_PRIVATE_KEY=                # see header for generation steps
RS256_PUBLIC_KEY=

# ── AWS (for nightly backups + S3 uploads) ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=pgmanage-prod-uploads

# ── External integrations (defer until ready) ─────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
META_APP_SECRET=
SES_FROM_EMAIL=
