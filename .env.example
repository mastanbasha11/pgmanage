# ─── Core ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Alternatives: staging | production

# ─── Database ────────────────────────────────────────────────────────────────
# Local (docker-compose):
DATABASE_URL=postgresql+asyncpg://pgmanage:pgmanage@localhost:5432/pgmanage

# Production (from Secrets Manager at runtime):
# DATABASE_URL=postgresql+asyncpg://pgmanage:<password>@<rds-endpoint>:5432/pgmanage

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Production: redis://<elasticache-endpoint>:6379/0

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
# HS256 (dev): set SECRET_KEY only
SECRET_KEY=dev-secret-key-change-this-in-production-min-32-chars

# RS256 (production): set paths or base64-encoded key content
# JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=ap-south-1
S3_BUCKET_NAME=pgmanage-local

# LocalStack (dev only) — set to "true" to use http://localhost:4566
USE_LOCALSTACK=true
LOCALSTACK_ENDPOINT=http://localhost:4566

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe Price IDs (from your Stripe dashboard)
STRIPE_PRICE_STARTER=price_replace_starter
STRIPE_PRICE_GROWTH=price_replace_growth
STRIPE_PRICE_ENTERPRISE=price_replace_enterprise

# ─── WhatsApp / Meta ─────────────────────────────────────────────────────────
# Per-org WABA credentials are stored in Secrets Manager, not here.
# For dev, set ENVIRONMENT=development and messages are logged to stdout.
META_APP_SECRET=meta_app_secret_for_webhook_verification

# ─── Notifications ───────────────────────────────────────────────────────────
# SES sender address (must be verified in AWS SES)
SES_FROM_EMAIL=noreply@pgmanage.com

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_OTP_PER_MIN=5
RATE_LIMIT_LOGIN_PER_MIN=10

# ─── Super Admin ─────────────────────────────────────────────────────────────
PLATFORM_ADMIN_SECRET=platform-admin-secret-change-this
